<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.SmartMedicationHelper" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorControlActivated">@color/main_coral</item>
        <item name="android:textCursorDrawable">@drawable/edit_text_cursor_coral</item>
        <item name="fontFamily">@font/samsungsans_regular</item>
        <item name="android:fontFamily">@font/samsungsans_regular</item>
    </style>

    <style name="Theme.SmartMedicationHelper" parent="Base.Theme.SmartMedicationHelper" />

    <!-- BottomNavigationView 글자 크기 조절용 스타일 -->
    <style name="BottomNavText.Active" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="textAllCaps">false</item>
    </style>

    <style name="BottomNavText.Inactive" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">10sp</item>
        <item name="textAllCaps">false</item>
    </style>
</resources>
