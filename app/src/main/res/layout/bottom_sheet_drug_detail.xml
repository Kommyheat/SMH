<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="16dp"
    android:paddingBottom="32dp">

    <!-- 핸들 바 -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="#DDDDDD" />

    <!-- 카테고리명 (예: 감기약) -->
    <TextView
        android:id="@+id/tv_bs_drug_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="약 이름"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <!-- 복용 시간대 -->
    <TextView
        android:id="@+id/tv_bs_time_slot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="아침 복용"
        android:textColor="#FF786E"
        android:textSize="13sp"
        android:layout_marginBottom="12dp" />

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginBottom="16dp" />

    <!-- 로딩 스피너 -->
    <ProgressBar
        android:id="@+id/progress_bs"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center_horizontal"
        android:visibility="gone" />

    <!-- 에러 메시지 -->
    <TextView
        android:id="@+id/tv_bs_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="저장된 약 상세정보가 없습니다."
        android:textColor="#888888"
        android:textSize="14sp"
        android:visibility="gone" />

    <!-- 약품별 상세정보 목록 (동적으로 추가) -->
    <ScrollView
        android:id="@+id/scroll_bs_detail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/layout_bs_drug_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

</LinearLayout>
