<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:clipChildren="false">

    <!-- 뒷 레이어: 삭제 버튼 (스와이프 시 노출) -->
    <LinearLayout
        android:id="@+id/layout_delete_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_schedule_item_pending_coral"
        android:gravity="center_vertical|end"
        android:paddingEnd="20dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btn_delete_schedule"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_delete"
            android:contentDescription="삭제"
            app:tint="@color/white" />
    </LinearLayout>

    <!-- 앞 레이어: 약 정보 (스와이프로 밀리는 뷰) -->
    <LinearLayout
        android:id="@+id/layout_swipe_foreground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_schedule_item_pending"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="3dp"
        android:paddingEnd="12dp"
        android:paddingBottom="3dp">

        <TextView
            android:id="@+id/tv_category_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="감기약"
            android:textColor="@color/dark_gray"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_take_done"
            android:layout_width="72dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_schedule_done_button_pending"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="미완료"
            android:textColor="@color/dark_gray"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</FrameLayout>
